FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///socialsense.db
YOUTUBE_API_KEY=

# Reddit API (optional - enables live Reddit analysis)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SocialSenseAI/1.0

# Transcript Analysis (V7)
ENABLE_TRANSCRIPT_ANALYSIS=true
TRANSCRIPT_LANGUAGE_PRIORITY=en,en-US,en-GB,en-IN,hi
ENABLE_TRANSCRIPT_FALLBACK_DEMO=true
TRANSCRIPT_CACHE_ENABLED=true
TRANSCRIPT_RETENTION_DAYS=90

# Entity Intelligence (V8)
ENABLE_ENTITY_ANALYSIS=true
ENABLE_ENTITY_SENTIMENT=true
ENABLE_ENTITY_RISK=true
MAX_ENTITIES_PER_ANALYSIS=100
ENTITY_MIN_IMPORTANCE=5

# Channel Context Intelligence (V9)
ENABLE_CHANNEL_INTELLIGENCE=true
ENABLE_HISTORICAL_CONTEXT=true
MAX_HISTORY_VIDEOS=100
MAX_ENTITY_HISTORY=500
