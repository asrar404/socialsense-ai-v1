FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///socialsense.db
YOUTUBE_API_KEY=

# Reddit API (optional - enables live Reddit analysis)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SocialSenseAI/1.0

# Transcript Analysis (V7)
ENABLE_TRANSCRIPT_ANALYSIS=true
TRANSCRIPT_LANGUAGE_PRIORITY=en,en-US,en-GB,en-IN,hi
ENABLE_TRANSCRIPT_FALLBACK_DEMO=true
TRANSCRIPT_CACHE_ENABLED=true
TRANSCRIPT_RETENTION_DAYS=90
